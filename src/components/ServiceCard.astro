---
interface Props {
  icon: string;
  title: string;
  description: string;
  link: string;
  backgroundImage?: string;
}

const { icon, title, description, link, backgroundImage } = Astro.props;
---

<div class="glass-card service-card" style={backgroundImage ? `background-image: url('${backgroundImage}')` : ''}>
  <div class="dark-overlay"></div>
  <div class="card-content">
    <div class="icon-wrapper">
      <span>{icon}</span>
    </div>
    <div class="title-section">
      <h3>{title}</h3>
      <div class="card-details">
        <p>{description}</p>
        <a href={link} class="link-more" target={link.startsWith('http') ? '_blank' : '_self'} rel={link.startsWith('http') ? 'noopener noreferrer' : ''}>Learn More <span>&rarr;</span></a>
      </div>
    </div>
  </div>
</div>

<style>
  .service-card {
    background: var(--card-bg);
    background-size: 100% 100%;
    background-position: center;
    background-repeat: no-repeat;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    height: 100%;
    padding: 32px;
    border-radius: 16px;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
    border: 1px solid var(--card-border);
    box-shadow: var(--card-shadow);
  }

    .card-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    height: 100%;
    color: white;
  }

  .card-content h3 {
    color: white;
  }

  .card-content p {
    color: rgba(255, 255, 255, 0.9);
  }

  .card-content .link-more {
    color: white;
  }

  .service-card::after {
    display: none;
  }

  .dark-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.6);
    z-index: 1;
    transition: background 0.4s ease;
  }

  .card-details {
    opacity: 0;
    visibility: hidden;
    transform: translateY(20px);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .service-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(124, 58, 237, 0.15);
    border-color: var(--primary-pink);
  }

  .service-card:hover .dark-overlay {
    background: rgba(0, 0, 0, 0.8);
  }

  .service-card:hover .card-details {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }


  .icon-wrapper {
    background: linear-gradient(135deg, rgba(124, 58, 237, 0.15), rgba(219, 39, 119, 0.1));
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    margin-bottom: 24px;
    font-size: 1.8rem;
    color: var(--primary-purple);
    border: 1px solid rgba(124, 58, 237, 0.1);
    transition: all 0.3s ease;
    position: relative;
  }

  .icon-wrapper::after {
    content: '';
    position: absolute;
    top: -2px;
    left: -2px;
    right: -2px;
    bottom: -2px;
    background: var(--primary-gradient);
    border-radius: 12px;
    opacity: 0;
    z-index: -1;
    transition: opacity 0.3s ease;
  }

  .service-card:hover .icon-wrapper {
    transform: scale(1.1) rotate(5deg);
    box-shadow: 0 8px 25px rgba(124, 58, 237, 0.25);
  }

  .service-card:hover .icon-wrapper::after {
    opacity: 1;
  }

  
  h3 {
    margin-top: auto;
    margin-bottom: 16px;
    font-size: 1.5rem;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  p {
    color: var(--text-muted);
    margin-bottom: 30px;
    font-size: 1rem;
    flex-grow: 1;
    transition: all 0.3s ease;
  }

  .service-card:hover h3 {
    color: white;
    transform: translateX(4px);
  }

  .service-card:hover p {
    color: rgba(255, 255, 255, 0.9);
  }

  .link-more {
    font-family: var(--font-heading);
    font-weight: 500;
    color: white;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: all 0.3s ease;
    position: relative;
  }

  .link-more::before {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--primary-gradient);
    transition: width 0.3s ease;
  }

  .link-more span {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    display: inline-block;
  }

  .service-card:hover .link-more {
    color: white;
    transform: translateX(2px);
  }

  .service-card:hover .link-more::before {
    width: 100%;
  }

  .service-card:hover .link-more span {
    transform: translateX(8px);
    color: white;
  }
</style>
