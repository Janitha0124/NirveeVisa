---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-grid">
    <div class="footer-info">
      <h3>Nirvee <span class="gold-text">Visa</span></h3>
      <p>Elevating your immigration experience. We provide premium, bespoke solutions for your global mobility needs.</p>
    </div>

    <div class="footer-links">
      <h4>Company</h4>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/about">About Us</a></li>
        <li><a href="/testimonials">Testimonials</a></li>
      </ul>
    </div>

    <div class="footer-links">
      <h4>Capabilities</h4>
      <ul>
        <li><a href="/services">Services</a></li>
        <li><a href="/programs">Programs</a></li>
      </ul>
    </div>

    <div class="footer-contact">
      <h4>Contact</h4>
      <p>123 Obsidian Tower, Suite 400</p>
      <p>Phone: +1 (234) 567-890</p>
      <p><a href="/contact" class="gold-text">Reach Out &rarr;</a></p>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container bottom-content">
      <p>&copy; {currentYear} Nirvee Visa Premium Consulting. All Rights Reserved.</p>
      <div class="legal-links">
        <a href="/privacy">Privacy Policy</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--obsidian-light);
    color: var(--white);
    padding: 100px 0 30px;
    margin-top: 100px;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1.5fr;
    gap: 60px;
    margin-bottom: 80px;
  }

  .footer-info h3 {
    margin-bottom: 24px;
    font-size: 1.8rem;
    letter-spacing: 1px;
  }

  .footer-info p {
    color: var(--text-muted);
    font-size: 1rem;
    max-width: 300px;
  }

  .footer-links h4, .footer-contact h4 {
    color: var(--gold);
    margin-bottom: 30px;
    font-size: 1.2rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .footer-links ul li {
    margin-bottom: 16px;
  }

  .footer-links ul li a {
    color: var(--text-muted);
    transition: var(--transition);
  }

  .footer-links ul li a:hover {
    color: var(--white);
    padding-left: 8px;
    border-left: 2px solid var(--gold);
  }

  .footer-contact p {
    color: var(--text-muted);
    margin-bottom: 16px;
  }

  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.05);
    padding-top: 30px;
  }

  .bottom-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .legal-links {
    display: flex;
    gap: 24px;
  }

  .legal-links a:hover {
    color: var(--gold);
  }

  .gold-text {
    color: var(--gold);
  }

  @media (max-width: 992px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 600px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
    .bottom-content {
      flex-direction: column;
      gap: 20px;
      text-align: center;
    }
  }
</style>
