---
const navLinks = [
  { name: 'Home', href: '/' },
  { name: 'Programs', href: '/programs' },
  { name: 'Services', href: '/services' },
  { name: 'Testimonials', href: '/testimonials' },
  { name: 'About Us', href: '/about' },
  { name: 'Contact Us', href: '/contact' }
];
---

<header class="header">
  <div class="container nav-container">
    <div class="logo">
      <a href="/">Nirvee <span class="gold-text">Visa</span></a>
    </div>
    <nav class="nav">
      <ul class="nav-list">
        {navLinks.map(link => (
          <li><a href={link.href} class="nav-link">{link.name}</a></li>
        ))}
      </ul>
      <a href="/contact" class="btn btn-outline eligibility-btn">Start Journey</a>
    </nav>
    <div class="mobile-menu-btn">
      <span></span>
      <span></span>
      <span></span>
    </div>
  </div>
</header>

<style>
  .header {
    background-color: var(--obsidian);
    padding: 24px 0;
    position: sticky;
    top: 0;
    z-index: 1000;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    transition: var(--transition);
  }

  .nav-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo a {
    color: var(--white);
    font-size: 1.75rem;
    font-weight: 800;
    letter-spacing: 2px;
    font-family: var(--font-heading);
  }

  .gold-text {
    color: var(--gold);
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 48px;
  }

  .nav-list {
    display: flex;
    gap: 32px;
  }

  .nav-link {
    color: var(--text-main);
    font-weight: 500;
    font-size: 0.95rem;
    position: relative;
    letter-spacing: 0.02em;
    font-family: var(--font-heading);
  }

  .nav-link:after {
    content: '';
    position: absolute;
    bottom: -6px;
    left: 0;
    width: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--gold), transparent);
    transition: var(--transition);
  }

  .nav-link:hover {
    color: var(--white);
  }

  .nav-link:hover:after {
    width: 100%;
  }

  .eligibility-btn {
    padding: 10px 28px;
    font-size: 0.9rem;
    border-radius: 4px;
  }

  .mobile-menu-btn {
    display: none;
    flex-direction: column;
    gap: 6px;
    cursor: pointer;
  }

  .mobile-menu-btn span {
    width: 28px;
    height: 2px;
    background-color: var(--white);
    transition: var(--transition);
  }

  @media (max-width: 992px) {
    .nav {
      display: none;
    }
    .mobile-menu-btn {
      display: flex;
    }
  }
</style>
