---
import MainLayout from '../layouts/MainLayout.astro';

const team = [
  { name: 'Sarah Johnson', role: 'Chief Immigration Officer', image: '👩‍💼' },
  { name: 'Michael Chen', role: 'Senior Visa Consultant', image: '👨‍💼' },
  { name: 'Emma Williams', role: 'Student Visa Specialist', image: '👩‍💼' },
  { name: 'David Smith', role: 'Business Migration Expert', image: '👨‍💼' }
];
---

<MainLayout title="About Us">
  <section class="page-header section-padding">
    <div class="container text-center">
      <h1>Leading the Way in Global Mobility</h1>
      <p class="subtitle">With over a decade of experience, we've helped thousands of individuals and families find their new home through expert immigration guidance.</p>
    </div>
  </section>

  <section class="about-content section-padding">
    <div class="container grid-2">
      <div class="about-text">
        <h2>Our Mission</h2>
        <p>At ImmigraSite, our mission is simple: to make the complex world of immigration accessible and straightforward. We believe that global mobility should be a transparent and empowering experience for everyone.</p>
        <p>Our team of dedicated professionals stays at the forefront of changing immigration laws and policies to ensure your application has the highest chance of success.</p>
        
        <div class="values">
          <div class="value-item">
            <span class="value-icon">✓</span>
            <div>
              <h4>Integrity First</h4>
              <p>We provide honest assessments and realistic expectations from day one.</p>
            </div>
          </div>
          <div class="value-item">
            <span class="value-icon">✓</span>
            <div>
              <h4>Client Centric</h4>
              <p>Every case is unique, and we tailor our approach to your specific goals.</p>
            </div>
          </div>
        </div>
      </div>
      <div class="about-image glass">
        <!-- Placeholder for professional office image -->
        <div class="image-placeholder flex-center">
          <span>Trust & Expertise</span>
        </div>
      </div>
    </div>
  </section>

  <section class="team section-padding bg-light">
    <div class="container text-center">
      <h2>Meet Our Experts</h2>
      <p class="section-subtitle">Dedicated professionals committed to your success.</p>
      
      <div class="team-grid">
        {team.map(member => (
          <div class="team-card">
            <div class="team-avatar">{member.image}</div>
            <h3>{member.name}</h3>
            <p>{member.role}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .page-header {
    background-color: var(--primary-color);
    color: var(--white);
  }

  .page-header h1 { color: var(--white); }
  
  .subtitle {
    margin-top: 20px;
    font-size: 1.2rem;
    color: var(--gray-light);
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }

  .grid-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .about-text h2 { margin-bottom: 25px; }
  .about-text p { margin-bottom: 20px; color: #4B5563; }

  .values { margin-top: 40px; }
  .value-item {
    display: flex;
    gap: 20px;
    margin-bottom: 30px;
  }

  .value-icon {
    background: var(--accent-gold);
    width: 24px;
    height: 24px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--primary-color);
    font-weight: bold;
    flex-shrink: 0;
  }

  .value-item h4 { margin-bottom: 5px; }

  .image-placeholder {
    height: 400px;
    background: linear-gradient(135deg, var(--secondary-color), var(--primary-color));
    border-radius: 20px;
    color: var(--accent-gold);
    font-size: 1.5rem;
    font-weight: bold;
  }

  .bg-light { background-color: #F9FAFB; }

  .section-subtitle { margin-bottom: 50px; color: #4B5563; }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 30px;
  }

  .team-card {
    background: var(--white);
    padding: 30px;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.05);
  }

  .team-avatar {
    font-size: 3rem;
    margin-bottom: 20px;
  }

  .team-card h3 { font-size: 1.25rem; margin-bottom: 10px; }
  .team-card p { color: var(--secondary-color); font-weight: 500; font-size: 0.9rem; }

  @media (max-width: 992px) {
    .grid-2 { grid-template-columns: 1fr; }
  }
</style>
