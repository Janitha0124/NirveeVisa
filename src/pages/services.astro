---
import MainLayout from '../layouts/MainLayout.astro';

const services = [
  {
    icon: '🏢',
    title: 'Corporate Mobility',
    description: 'Bespoke strategic mobility solutions designed specifically for multinational enterprises scaling their global footprint.',
  },
  {
    icon: '🎓',
    title: 'Elite Student Visas',
    description: 'Premier academic transition support to secure placements in top-tier global institutions without bureaucratic friction.',
  },
  {
    icon: '🌟',
    title: 'Global Talent',
    description: 'Fast-tracked, red-carpet routes for pioneers in STEM, arts, and business wishing to relocate to major global hubs.',
  },
  {
    icon: '⚖️',
    title: 'Strategic Consultation',
    description: 'Rigorous legal roadmapping for complex immigration appeals, ensuring compliance and maximizing success rates.',
  },
  {
    icon: '🛡️',
    title: 'Compliance Audits',
    description: 'Meticulous review of corporate sponsorship frameworks to guarantee alignment with stringent global immigration laws.',
  },
  {
    icon: '💼',
    title: 'Investor Relocation',
    description: 'Expedited residency and citizenship pathways via strategic high-value asset investment.',
  }
];
---

<MainLayout title="Capabilities" description="Premium corporate and individual immigration capabilities.">
  <section class="page-header section-padding">
    <div class="container text-center">
      <span class="gold-text uppercase-label">Our Capabilities</span>
      <h1>Immigration Services</h1>
      <p class="subtitle">We deliver white-glove, end-to-end immigration strategies tailored for elite professionals, investors, and elite corporations.</p>
    </div>
  </section>

  <section class="services-list section-padding">
    <div class="container">
      <div class="grid services-grid">
        {services.map(service => (
          <div class="glass-card service-card">
            <div class="icon-wrapper">
              <span>{service.icon}</span>
            </div>
            <h3>{service.title}</h3>
            <p>{service.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="process section-padding bg-darker">
    <div class="container">
      <h2 class="text-center">The Nirvee Visa Methodology</h2>
      <p class="text-center subtitle mb-60">A proprietary four-phase framework ensuring unparalleled precision.</p>
      
      <div class="process-grid">
        <div class="process-step">
          <div class="step-num">01</div>
          <h3>Strategic Consultation</h3>
          <p>Initial executive assessment aligning your global mobility ambitions with legislative realities.</p>
        </div>
        <div class="process-step">
          <div class="step-num">02</div>
          <h3>Blueprint Creation</h3>
          <p>Developing a bespoke, risk-mitigated roadmap for your specific jurisdictional target.</p>
        </div>
        <div class="process-step">
          <div class="step-num">03</div>
          <h3>Rigorous Audit</h3>
          <p>Meticulous documentation compilation and preemptive legal stress-testing of your portfolio.</p>
        </div>
        <div class="process-step">
          <div class="step-num">04</div>
          <h3>Execution & Grant</h3>
          <p>Seamless liaison with government bodies to secure a rapid and unencumbered approval.</p>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .page-header {
    background: linear-gradient(to bottom, var(--obsidian-light), var(--obsidian));
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    padding-top: 150px;
    padding-bottom: 80px;
  }

  .uppercase-label {
    display: inline-block;
    font-family: var(--font-heading);
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 16px;
    font-size: 0.9rem;
  }

  .subtitle {
    margin-top: 20px;
    font-size: 1.25rem;
    color: var(--text-muted);
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }
  
  .mb-60 { margin-bottom: 60px; }

  .services-grid {
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 40px;
  }

  .service-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .icon-wrapper {
    background: linear-gradient(135deg, rgba(212, 175, 55, 0.15), rgba(212, 175, 55, 0.05));
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    margin-bottom: 24px;
    font-size: 1.8rem;
    color: var(--gold);
    border: 1px solid rgba(212, 175, 55, 0.2);
  }

  .service-card h3 {
    margin-bottom: 16px;
    font-size: 1.5rem;
    font-weight: 600;
  }

  .service-card p {
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 0;
  }

  .bg-darker {
    background-color: var(--obsidian-lighter);
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .process-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 40px;
    position: relative;
  }

  .process-step {
    text-align: left;
    position: relative;
    padding: 30px;
    background: rgba(0, 0, 0, 0.2);
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition: var(--transition);
  }

  .process-step:hover {
    border-color: rgba(212, 175, 55, 0.3);
    transform: translateY(-5px);
  }

  .step-num {
    font-family: var(--font-heading);
    font-size: 3rem;
    font-weight: 800;
    color: var(--gold);
    opacity: 0.3;
    line-height: 1;
    margin-bottom: 20px;
  }

  .process-step h3 {
    font-size: 1.3rem;
    margin-bottom: 16px;
  }

  .process-step p {
    color: var(--text-muted);
    font-size: 0.95rem;
    margin-bottom: 0;
  }

  @media (max-width: 768px) {
    .page-header { padding-top: 100px; }
    .process-grid { grid-template-columns: 1fr; }
  }
</style>
